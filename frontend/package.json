{
	"name": "frontend",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"preview": "vite preview",
		"lint": "biome check --max-diagnostics=4294967295 ./src",
		"lint:fix": "biome check --max-diagnostics=4294967295 --write ./src",
		"format": "biome format --write ./src",
		"knip": "knip",
		"doc": "npx typedoc --out docs --entryPointStrategy Expand ./src"
	},
	"dependencies": {
		"@tailwindcss/vite": "^4.3.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-router": "^7.15.0",
		"tailwindcss": "^4.3.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"@eslint/js": "^9.39.4",
		"@types/node": "^24.12.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"eslint": "^9.39.4",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"globals": "^17.4.0",
		"knip": "^6.12.2",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.57.0",
		"vite": "^8.0.1"
	}
}
